RAEBURN_ENV=development
RAEBURN_PUBLIC_BASE_URL=http://localhost:3000
RAEBURN_API_BASE_URL=http://localhost:8080
RAEBURN_API_KEY=change-me-use-a-secret-manager-in-production
RAEBURN_SECRETS_KEY=change-me-32-byte-minimum
RAEBURN_CORS_ORIGINS=http://localhost:3000
RAEBURN_RATE_LIMIT_PER_MINUTE=60
DATABASE_URL=postgresql+psycopg://raeburn:raeburn@postgres:5432/meeting_intelligence
REDIS_URL=redis://redis:6379/0

# LLM provider: deterministic | openai_compatible
LLM_PROVIDER=deterministic
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4.1-mini

# Integrations are disabled until explicitly enabled.
GITHUB_WRITEBACK_ENABLED=false
GITHUB_TOKEN=
GITHUB_DEFAULT_REPOSITORY=

JIRA_WRITEBACK_ENABLED=false
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

CRM_WRITEBACK_ENABLED=false
CRM_PROVIDER=hubspot
CRM_API_KEY=

EMAIL_FOLLOWUP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

WEBHOOK_WRITEBACK_ENABLED=false
WEBHOOK_URL=

APPROVALS_REQUIRED=true
AUDIT_LOG_LEVEL=INFO
